# мһҘлҸ…лҢҖ Airflow мқҙлҜём§Җ (м„Өкі„ 00 В§12.3)
#
# Airflow мҪ”м–ҙлҠ” SQLAlchemy 1.4, мһҘлҸ…лҢҖ м•ұмқҖ SQLAlchemy 2.0мқ„ м“°лҜҖлЎң н•ң нҷҳкІҪм—җ лӘ» м„һлҠ”лӢӨ.
# вҶ’ м•ұ мқҳмЎҙм„ұмқ„ лі„лҸ„ venv(/home/airflow/jangdokdae-venv)м—җ кІ©лҰ¬н•ҳкі , DAGлҠ”
#   ExternalPythonOperatorлЎң мқҙ venvмқҳ pythonмқ„ нҳём¶ңн•ңлӢӨ. Airflow мҪ”м–ҙ нҷҳкІҪмқҖ лІ мқҙмҠӨ к·ёлҢҖлЎң.
ARG AIRFLOW_VERSION=3.0.0
FROM apache/airflow:${AIRFLOW_VERSION}-python3.12

# hdbscan л“ұ л„ӨмқҙнӢ°лёҢ л№Ңл“ңмҡ© м»ҙнҢҢмқјлҹ¬ (arm64 нң мқҙ м—Ҷмқ„ л•Ң лҢҖл№„)
USER root
RUN apt-get update \
    && apt-get install -y --no-install-recommends gcc g++ \
    && rm -rf /var/lib/apt/lists/*
USER airflow

# м•ұ м „мҡ© venv вҖ” м•ұ мқҳмЎҙм„ұ(SQLA 2.0 л“ұ)мқ„ Airflow мҪ”м–ҙ(1.4)мҷҖ л¶„лҰ¬
COPY requirements-airflow.txt /requirements-airflow.txt
RUN python -m venv /home/airflow/jangdokdae-venv \
    && /home/airflow/jangdokdae-venv/bin/pip install --no-cache-dir --upgrade pip \
    && /home/airflow/jangdokdae-venv/bin/pip install --no-cache-dir -r /requirements-airflow.txt
