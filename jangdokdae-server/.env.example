# 앱 설정
APP_NAME=장독대
DEBUG=False

# 데이터베이스
DATABASE_URL=postgresql://user:password@localhost/jangdokdae

# OAuth (client secret은 BE에만 보관 — FE 번들에 절대 노출 금지)
# redirect_uri는 provider 콘솔 등록값과 정확히 일치해야 함: {backend}/api/v1/auth/{provider}/callback
OAUTH_KAKAO_CLIENT_ID=your_kakao_client_id
OAUTH_KAKAO_CLIENT_SECRET=your_kakao_client_secret
OAUTH_KAKAO_REDIRECT_URI=http://localhost:8000/api/v1/auth/kakao/callback

OAUTH_GOOGLE_CLIENT_ID=your_google_client_id
OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# JWT / 세션 쿠키
SECRET_KEY=your_secret_key_here  # openssl rand -hex 32
ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token

COOKIE_SECURE=False  # 운영(HTTPS)에서 True
COOKIE_SAMESITE=lax
# 운영 도메인 지정(예: .jangdokdae.com) — 빈 값에 인라인 주석을 붙이면 주석이 값으로 파싱되니 줄을 분리한다
COOKIE_DOMAIN=

# 프론트엔드 (로그인 완료·온보딩 redirect 대상)
FRONTEND_BASE_URL=http://localhost:3000

# Gemini Vertex AI (Google Cloud 크레딧 적용)
# vertex ai 인증
GOOGLE_APPLICATION_CREDENTIALS=app/credentials/vertex_key.json
GOOGLE_CLOUD_PROJECT=kt-cloud-jangdokdae
GOOGLE_CLOUD_LOCATION=asia-northeast3
VERTEX_MODEL=gemini-2.5-flash  # 3.5-flash는 asia-northeast3 미존재(404)

# 뉴스 수집
OPENDART_API_KEY=
ECOS_API_KEY=
DICTIONARY_ADMIN_TOKEN=

# KRX 로그인 정보 -> 회원가입 필요
KRX_ID=
KRX_PW=

# Embedding — bake-off(2026-06-22) 선정: ko-sroberta(768)+title_body+HDBSCAN (docs/evaluation/02~08)
EMBED_MODEL=jhgan/ko-sroberta-multitask
EMBED_DIM=768  # ko-sroberta-multitask 네이티브 768 — 현 Vector(768) 스키마 유지
EMBED_BATCH_SIZE=50
EMBED_TITLE_WEIGHT=0.3  # 제목+본문 가중평균 α (α·제목 + (1-α)·본문, 각 L2 정규화 후)
CLUSTER_WINDOW_DAYS=14  # 이벤트 기반 재클러스터링 윈도우(최근 N일 전체 재계산)

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Airflow Web UI (SimpleAuthManager admin 계정 비밀번호 — docker-compose 기동 시 주입)
AIRFLOW_ADMIN_PASSWORD=

# Airflow Task Execution API JWT secret — 전 컨테이너 동일값 필수(3.0+, 미설정 시 각자 랜덤→403).
# 생성: openssl rand -hex 32
AIRFLOW__API_AUTH__JWT_SECRET=
